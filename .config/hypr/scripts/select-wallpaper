#!/bin/bash
# ==============================================================================
# Select Wallpaper with Parallel Thumbnail Caching
# Optimized for Wofi and Awww (Handles 1000+ wallpapers efficiently)
# ==============================================================================

# Directory for wallpapers
DIR="$HOME/Pictures/wallpapers-redblizard/"
CACHE_DIR="$HOME/.cache/awww"
CURRENT_CACHE="$CACHE_DIR/current_wallpaper.png"
THUMB_DIR="$HOME/.cache/select-wallpaper"

# Wofi configuration paths for the wallpaper picker
WOFI_CONFIG="$HOME/.config/wofi/dmenu-launcher/config"
WOFI_STYLE="$HOME/.config/wofi/dmenu-launcher/style.css"

# Thumbnail size (300x180 is the sweet spot for speed and quality)
THUMB_SIZE="250x150"

mkdir -p "$CACHE_DIR"
mkdir -p "$THUMB_DIR"

# 1. Stop the random wallpaper loop if it's running in the background
if pgrep -f "random-wallpaper" >/dev/null; then
    pkill -f "random-wallpaper"
    echo "Stopped random-wallpaper loop at $(date)" >> "$CACHE_DIR/no_wallpaper_loop.log"
fi

# 2. Stop existing awww-daemon if it's running
if pgrep -x awww-daemon >/dev/null; then
    pkill -x awww-daemon
    echo "Stopped awww-daemon at $(date)" >> "$CACHE_DIR/no_wallpaper_loop.log"
    sleep 0.5 # Give the daemon a moment to cleanly release resources
fi

# 3. Start awww-daemon fresh
echo "Starting awww-daemon at $(date)" >> "$CACHE_DIR/no_wallpaper_loop.log"
awww-daemon & disown

# ==============================================================================
# PHASE 1: Parallel Thumbnail Generation
# ==============================================================================
# Export THUMB_DIR so the subshells spawned by xargs can access it
export THUMB_DIR

# Find all images and process them in parallel using all available CPU cores (-P $(nproc))
# -print0 and -0 are used to safely handle filenames with spaces
find "${DIR}" -type f \( -iname "*.jpg" -o -iname "*.png" -o -iname "*.gif" \) -print0 | \
xargs -0 -P $(nproc) -I {} bash -c '
    img="{}"
    thumb="$THUMB_DIR/$(basename "$img").png"
    
    # Only generate if missing or if original is newer than thumbnail
    if [[ ! -f "$thumb" || "$img" -nt "$thumb" ]]; then
        # [0] ensures we only take the first frame for gifs
        magick "$img[0]" -thumbnail '"$THUMB_SIZE"'^ -gravity center -extent '"$THUMB_SIZE"' "$thumb" 2>/dev/null
    fi
'

# ==============================================================================
# PHASE 2: Build Wofi UI & Select
# ==============================================================================
select_wp() {
    # Since thumbnails are now guaranteed to exist, we just map them quickly
    CHOICE=$(find "${DIR}" -type f \( -iname "*.jpg" -o -iname "*.png" -o -iname "*.gif" \) | sort | while IFS= read -r f; do
        thumb="$THUMB_DIR/$(basename "$f").png"
        printf 'img:%s:text: \n' "$thumb"
    done | wofi --show dmenu \
    --conf "$WOFI_CONFIG" \
    --style "$WOFI_STYLE" \
    --prompt "Select Wallpaper" \
    --cache-file /dev/null)

    # Exit if user cancelled
    [ -z "$CHOICE" ] && exit 0

    # Extract the thumbnail path from the returned 'img:/path:text: ' string
    THUMB_PATH=$(echo "$CHOICE" | sed 's/^img:\(.*\):text:.*$/\1/')
    
    # Map thumbnail back to original file
    THUMB_BASENAME=$(basename "$THUMB_PATH")
    ORIGINAL_NAME="${THUMB_BASENAME%.png}"
    FULLPATH="${DIR}/${ORIGINAL_NAME}"

    # Fallback check just in case
    if [ ! -f "$FULLPATH" ]; then
        FULLPATH=$(find "${DIR}" -name "$ORIGINAL_NAME" | head -1)
    fi

    if [ -n "$FULLPATH" ] && [ -f "$FULLPATH" ]; then
        set_wallpaper "$FULLPATH"
    else
        echo "Error: Could not find original file for $ORIGINAL_NAME"
    fi
}

# ==============================================================================
# Set Wallpaper Function
# ==============================================================================
set_wallpaper() {
    local img="$1"
    # Change wallpaper using awww with transition effects
    awww img "$img" --transition-step 20 --transition-fps=20
    # Copy the selected wallpaper to cache for other tools (waybar, hyprlock)
    cp "$img" "$CURRENT_CACHE"
}

# Launch the selector directly
select_wp
